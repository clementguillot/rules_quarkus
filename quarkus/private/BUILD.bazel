java_test(
    name = "bazel_jacoco_reporter_failure_test",
    srcs = ["BazelJacocoReporterFailureTest.java"],
    main_class = "io.quarkus.bazel.coverage.BazelJacocoReporterFailureTest",
    use_testrunner = False,
    deps = [":bazel_jacoco_reporter_lib"],
)

model_catalogs_test_suite()
